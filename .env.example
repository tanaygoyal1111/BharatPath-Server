PORT=5001
NODE_ENV=development

# Redis (Upstash REST)
UPSTASH_REDIS_REST_URL=https://your-pika.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Supabase
SUPABASE_URL=YOUR_SUPABASE_URL
